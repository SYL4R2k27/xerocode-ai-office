{
  "name": "xerocode-cli",
  "version": "0.1.0-beta.0",
  "description": "XeroCode AI — chat with a team of AI models from your terminal",
  "bin": {
    "xerocode": "./dist/cli.cjs"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.cjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "keywords": [
    "ai",
    "cli",
    "chat",
    "orchestration",
    "multi-model",
    "xerocode",
    "claude",
    "gpt",
    "gemini"
  ],
  "author": "XeroCode <hello@xerocode.ru> (https://xerocode.ru)",
  "license": "MIT",
  "homepage": "https://xerocode.ru",
  "repository": {
    "type": "git",
    "url": "https://github.com/SYL4R2k27/xerocode-ai-office.git",
    "directory": "xerocode-cli"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.1.6",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "marked": "^14.1.0",
    "marked-terminal": "^7.1.0",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "prompts": "^2.4.2",
    "string-width": "^8.2.0",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.5.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
