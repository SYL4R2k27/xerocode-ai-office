# ============================================
# XeroCode AI Office — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Database
DATABASE_URL=postgresql+asyncpg://ai_office:password@localhost:5432/ai_office

# Security (REQUIRED)
SECRET_KEY=CHANGE_ME_GENERATE_RANDOM_64_CHARS

# API Keys for Platform Pools (optional)
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Proxy (optional)
API_PROXY=socks5://127.0.0.1:10808

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=

# Email SMTP (optional)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# Payments (optional)
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
ALLOWED_ORIGINS=https://xerocode.space,https://xerocode.ru
